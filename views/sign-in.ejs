<% layout("layout") %>

<section class="auth">
  <div class="auth__card">
    <div class="auth__left">
      <h1 class="auth__title">Sign in</h1>
      <p class="auth__subtitle">Welcome back — continue your coursework.</p>

      <form class="auth__form" action="/sign-in" method="post">
        <label class="auth__label">
          Email
          <input class="auth__input" type="email" name="email" required />
        </label>

        <label class="auth__label">
          Password
          <input class="auth__input" type="password" name="password" required />
        </label>

        <button class="auth__button" type="submit">Sign in</button>

        <p class="auth__hint">
          Don’t have an account?
          <a class="auth__link" href="/sign-up">Create one</a>
        </p>
      </form>
    </div>

    <div class="auth__right" aria-hidden="true">
      <div class="auth__media">
        <img class="auth__image" src="/images/Log-in.jpg" alt="" />
      </div>
    </div>
  </div>
</section>

